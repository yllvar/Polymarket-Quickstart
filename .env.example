# Polymarket API Credentials
# Get these from your Polymarket account settings
POLY_API_KEY=your_api_key_here
POLY_API_SECRET=your_api_secret_here

# Wallet Configuration
# Choose ONE of the following wallet types:

# Option 1: EOA Wallet (signature_type=0)
# Traditional Ethereum wallet where you control the private key
PRIVATE_KEY=your_private_key_here  # Never share or commit this!
WALLET_ADDRESS=your_wallet_address_here

# Option 2: Proxy/Email Wallet (signature_type=1)
# Polymarket's email-based wallets where a funder address pays for gas
# FUNDER_ADDRESS=your_funder_address_here

# Additional Configuration
# Optional: Set custom API endpoints if needed
# GAMMA_API_URL=https://gamma-api.polymarket.com
# CLOB_API_URL=https://clob.polymarket.com

# Trading Safety Settings
# Optional: Set maximum trade sizes for safety
# MAX_TRADE_SIZE_USD=100.00
# REQUIRE_CONFIRMATION=true
